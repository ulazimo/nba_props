# ── The Odds API ──────────────────────────────────────────────────────────────
# Dobijte API ključ na: https://the-odds-api.com/
ODDS_API_KEY=your_odds_api_key_here

# ── NBA API tweaks ────────────────────────────────────────────────────────────
NBA_API_DELAY=1.0
NBA_API_RETRIES=5
NBA_API_BACKOFF=2.0

# ── Betting thresholds ────────────────────────────────────────────────────────
MIN_EDGE=0.05
MIN_PROBABILITY=0.55

# ── Kelly Criterion ───────────────────────────────────────────────────────────
KELLY_FRACTION=0.25
MAX_STAKE=5.0
MIN_STAKE=0.5

# ── Model parameters ──────────────────────────────────────────────────────────
HOME_COURT_PTS=2.5
B2B_PENALTY=3.0
BASE_STD_DEV=12.0
SCORE_WEIGHT=0.6
ELO_WEIGHT=0.4

# ── Season ────────────────────────────────────────────────────────────────────
CURRENT_SEASON=2025-26

# ── Scheduler times (24h HH:MM) ───────────────────────────────────────────────
SCHEDULE_EVALUATE_TIME=09:00
SCHEDULE_FETCH_TIME=10:00
SCHEDULE_PREDICT_TIME=22:00

# ── Props settings ────────────────────────────────────────────────────────────
PROPS_SEASON=2025-26
PROPS_RECENT_DAYS=20
PROPS_MIN_MINUTES=10.0
PROPS_MIN_GAMES=5
PROPS_STD_DEV_FACTOR=0.40
PROPS_ODDS_REGIONS=us
NBA_STATS_TIMEOUT=30
NBA_STATS_DELAY=1.0
